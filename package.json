{
  "name": "express-rate-guard",
  "version": "1.0.0",
  "description": "Flexible Express rate limiting middleware with Redis and in-memory support. Supports fixed window, sliding window, and token bucket strategies.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "express",
    "rate-limit",
    "rate-limiter",
    "throttle",
    "middleware",
    "redis",
    "token-bucket",
    "sliding-window"
  ],
  "author": "dillon-todd-dev",
  "license": "MIT",
  "peerDependencies": {
    "express": ">=4.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.4.0",
    "ioredis": "^5.10.0",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@10.32.0"
}
